name: Sync Leetcode

on:
  workflow_dispatch:      # Nút bấm để chạy tay bất cứ lúc nào
  schedule:
    - cron:  '0 16 * * *' # Tự động chạy mỗi ngày một lần (16h UTC ~ 23h VN)

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Sync
        uses: joshcai/leetcode-sync@v1.7
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          leetcode-csrf-token: ${{ secrets.LEETCODE_CSRF_TOKEN }}
          leetcode-session: ${{ secrets.LEETCODE_SESSION }}
          destination-folder: my-solutions
